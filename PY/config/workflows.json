        {
          "type": "tap",
          "x": 1851,
          "y": 1145,
          "comment": "点制式卷",
          "wait_after": 1
        },
        {
          "type": "tap",
          "x": 1600,
          "y": 1145,
          "comment": "点使用",
          "wait_after": 1
        },
        {
          "type": "tap",
          "x": 2680,
          "y": 1050,
