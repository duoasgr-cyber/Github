        },
        {
          "type": "wait",
          "seconds": 1,
          "comment": "等待返回完成"
        }
      ]
    },
    "begin": {
      "description": "开始匹配并重启游戏，等待进入入或开界面",
      "device_resolution": {
        "width": 2400,
        "height": 1080
      },
      "steps": [
        {
          "type": "tap",
          "x": 2392,
          "y": 1138,
          "comment": "点开始匹配",
          "wait_after": 15
        },
        {
          "type": "force_stop",
          "package": "com.tencent.tmgp.dfm",
          "comment": "强制停止三角洲",
          "wait_after": 0.5
        },
        {
          "type": "launch",
          "package": "com.tencent.tmgp.dfm",
          "comment": "启动三角洲",
          "wait_after": 25
        },
        {
          "type": "loop",
          "max_count": 500,
          "condition": {
            "type": "check_image",
            "template": "kai_1.jpg",
            "threshold": 0.85
          },
          "steps": [
            {
              "type": "wait",
              "seconds": 0.2,
              "comment": "等待后检查入界面"
            },
            {
              "type": "check_image",
              "template": "kai_1.jpg",
              "threshold": 0.85,
              "comment": "检查入界面"
            },
            {
              "type": "wait",
              "seconds": 0.2,
              "comment": "等待后检查开界面"
            },
            {
              "type": "check_image",
              "template": "kai_2.jpg",
              "threshold": 0.85,
              "comment": "检查开界面"
            }
          ],
          "comment": "轮询等待游戏启动，检测入(kai_1)或开(kai_2)界面，任一匹配即退出循环"
        }
      ]
    },
