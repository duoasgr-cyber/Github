    "after_buy": {
      "description": "购买后操作：使用制式卷、卸下装备、转移仓库物品",
      "device_resolution": {
        "width": 2400,
        "height": 1080
      },
      "steps": [
        {
          "type": "wait",
          "seconds": 3.0,
          "comment": "等待购买完成",
          "enabled": true,
          "display_name": ""
